<!-- ═══════════ HERO + CHOIX PATIENT/PRO ═══════════ -->
<section class="hero" aria-label="Présentation de l'établissement et orientation">
  <div class="hero-bg" style="background-image: url('<%= asset_path('hero-hospital.jpg') %>');" role="img" aria-label="Vue du Centre Hospitalier Polaris"></div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <span class="hero-kicker">Centre Hospitalier Polaris</span>
    <h1 class="hero-title">
      Prendre soin de la
      <span class="hero-title-accent">santé mentale</span>,<br>ensemble.
    </h1>
    <p class="hero-lead">Pour aller à l'essentiel, dites-nous ce qui vous intéresse</p>

    <div class="hero-doors">
      <%= link_to patients_path, class: "hero-door hero-door--patient",
          "aria-label": "Espace patients, familles et proches" do %>
        <span class="hero-door-top">
          <span class="hero-door-icon" aria-hidden="true">👤</span>
          <span class="hero-door-kicker">Patient & proches</span>
        </span>
        <span class="hero-door-desc">Mon CMP, mes droits, préparer une visite, urgences.</span>
        <span class="hero-door-cta">Entrer <span aria-hidden="true">→</span></span>
      <% end %>

      <%= link_to professionnels_path, class: "hero-door hero-door--pro",
          "aria-label": "Espace professionnels de santé" do %>
        <span class="hero-door-top">
          <span class="hero-door-icon" aria-hidden="true">🩺</span>
          <span class="hero-door-kicker">Professionnel</span>
        </span>
        <span class="hero-door-desc">Annuaire, ETP, échelles cliniques, adressage.</span>
        <span class="hero-door-cta">Entrer <span aria-hidden="true">→</span></span>
      <% end %>
    </div>
  </div>
</section>

<!-- ═══════════ CHIFFRES CLÉS ═══════════ -->
<div class="stats-band">
  <dl class="stats-band-inner" aria-label="Chiffres clés de l'établissement">
    <div class="stat-item">
      <dd class="stat-num"><%= Unit.where(unit_type: %w[ward_open ward_closed long_stay]).sum(:capacity) %></dd>
      <dt class="stat-label">Lits d'hospitalisation</dt>
    </div>
    <div class="stat-item">
      <dd class="stat-num">150</dd>
      <dt class="stat-label">Places ambulatoires</dt>
    </div>
    <div class="stat-item">
      <dd class="stat-num"><%= Pole.count %></dd>
      <dt class="stat-label">Pôles de soins</dt>
    </div>
    <div class="stat-item">
      <dd class="stat-num">650</dd>
      <dt class="stat-label">Professionnels</dt>
    </div>
  </dl>
</div>

<!-- ═══════════ URGENCES ═══════════ -->
<div class="urgences-banner" role="complementary" aria-label="Numéros d'urgence">
  <p>En cas de crise psychiatrique — <strong>15 (SAMU) · 3114 (Numéro national prévention suicide)</strong></p>
  <a href="#" class="urgences-btn">Accès urgences</a>
</div>

<!-- ═══════════ L'ÉTABLISSEMENT (bloc léger) ═══════════ -->
<div class="container">
  <section class="section" aria-labelledby="etab-title">
    <div class="section-header">
      <div>
        <span class="label">L'établissement</span>
        <h2 class="section-title" id="etab-title">Centre psychiatrique de référence depuis 1968</h2>
      </div>
      <%= link_to hopital_path, class: "hopital-cta-link" do %>
        Notre établissement →
      <% end %>
    </div>
    <p class="etab-intro">
      Le CH Polaris assure la prise en charge psychiatrique du territoire de Novapolis :
      adultes, enfants, addictologie et réhabilitation.
      <%= @poles.count %> pôles coordonnés, <%= Unit.count %> unités.
    </p>
    <div class="poles-mini-grid">
      <% @poles.each do |pole| %>
        <div class="pole-mini-card">
          <div class="pole-mini-accent" style="background-color: <%= pole.color %>;" aria-hidden="true"></div>
          <span class="pole-mini-name"><%= pole.name %></span>
          <span class="pole-mini-desc"><%= pole.description&.split('.')&.first %>.</span>
        </div>
      <% end %>
    </div>
  </section>
</div>

<!-- ═══════════ FOOTER ═══════════ -->
<footer class="site-footer" aria-label="Pied de page">
  <div class="footer-inner">
    <div>
      <p class="footer-brand">Centre Hospitalier Polaris</p>
      <address class="footer-address" style="font-style: normal;">
        12 rue des Astres<br>
        33999 Novapolis<br>
        <a href="tel:0599000000" style="color: #9ca3af; text-decoration: none;">05 99 00 00 00</a><br>
        <a href="mailto:contact@ch-polaris.fr" style="color: #9ca3af; text-decoration: none;">contact@ch-polaris.fr</a>
      </address>
    </div>
    <nav class="footer-col" aria-label="Accès rapide">
      <h6>Accès rapide</h6>
      <ul>
        <li><%= link_to "Patients & Familles", patients_path %></li>
        <li><%= link_to "Professionnels", professionnels_path %></li>
        <li><%= link_to "Notre établissement", hopital_path %></li>
        <li><a href="#">Urgences psychiatriques</a></li>
      </ul>
    </nav>
    <nav class="footer-col" aria-label="Informations légales">
      <h6>Informations légales</h6>
      <ul>
        <li><a href="#">Mentions légales</a></li>
        <li><a href="#">Accessibilité</a></li>
        <li><a href="#">Plan du site</a></li>
      </ul>
    </nav>
  </div>
  <div class="footer-bottom">
    <span>© <%= Date.today.year %> Centre Hospitalier Polaris — Novapolis · EPS</span>
    <span class="footer-fictif">⚠️ Projet fictif de démonstration — Pierre Gozard</span>
  </div>
</footer>
