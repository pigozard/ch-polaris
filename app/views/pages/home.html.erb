        12 rue des Astres<br>
        33999 Novapolis<br>
        <a href="tel:0599000000" style="color: rgba(255,255,255,0.4); text-decoration: none;">05 99 00 00 00</a><br>
        <a href="mailto:contact@ch-polaris.fr" style="color: rgba(255,255,255,0.4); text-decoration: none;">contact@ch-polaris.fr</a>
      </address>
    </div>
    <nav class="footer-col" aria-label="Accès rapide">
      <h6>Accès rapide</h6>
      <ul>
        <li><%= link_to "Patients & Familles", patients_path %></li>
        <li><%= link_to "Professionnels", professionnels_path %></li>
        <li><a href="#">Urgences psychiatriques</a></li>
        <li><a href="#">Nous contacter</a></li>
      </ul>
    </nav>
    <nav class="footer-col" aria-label="Informations légales">
      <h6>Informations légales</h6>
      <ul>
        <li><a href="#">Mentions légales</a></li>
        <li><a href="#">Accessibilité</a></li>
        <li><a href="#">Plan du site</a></li>
      </ul>
    </nav>
  </div>
  <div class="footer-bottom">
    <span>© <%= Date.today.year %> Centre Hospitalier Polaris — Novapolis · EPS</span>
    <span class="footer-fictif">⚠️ Projet fictif de démonstration — Pierre Gozard</span>
  </div>
</footer>
