<%# ═══════════ CSS ═══════════ %>
<style>
  .carte-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0 8px;
  }
  .carte-search-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f4f4f0;
    border: 1px solid #d8d5cc;
    border-radius: 8px;
    padding: 6px 12px;
    width: 100%;
    max-width: 420px;
  }
  .carte-search-wrap svg { color: #888; flex-shrink: 0; }
  #carte-search {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 13px;
    color: #2c2c2a;
  }
  .carte-clear-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #888;
    font-size: 13px;
    line-height: 1;
    padding: 0;
  }
  .carte-legend-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 8px 0;
    margin-bottom: 4px;
  }
  .carte-leg {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: #5f5e5a;
    cursor: pointer;
    padding: 3px 9px;
    border-radius: 5px;
    border: 1px solid transparent;
    transition: background .1s, border-color .1s;
  }
  .carte-leg:hover, .carte-leg.is-on {
    background: #fff;
    border-color: #d8d5cc;
  }
  .carte-leg-sq { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  .carte-main-wrap {
    display: flex;
    gap: 0;
    border: 1px solid #d8d5cc;
    border-radius: 10px;
    overflow: hidden;
  }
  .carte-svg-col { flex: 1; min-width: 0; }
  .carte-svg-col svg { display: block; width: 100%; }

  .carte-side-panel {
    width: 280px;
    flex-shrink: 0;
    background: #fff;
    border-left: 1px solid #e8e5dc;
    padding: 16px;
    overflow-y: auto;
    max-height: 780px;
    min-height: 200px;
  }
  .carte-panel-empty {
    color: #a0a098;
    font-size: 13px;
    text-align: center;
    padding-top: 40px;
    line-height: 1.7;
  }

  /* Éléments du panneau */
  .cp-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 8px;
  }
  .cp-name { font-size: 15px; font-weight: 600; color: #2c2c2a; margin-bottom: 3px; }
  .cp-type { font-size: 12px; color: #888; margin-bottom: 10px; }
  .cp-desc {
    font-size: 12px;
    color: #5f5e5a;
    line-height: 1.6;
    border-top: 1px solid #e8e5dc;
    padding-top: 10px;
    margin-bottom: 12px;
  }
  .cp-row {
    display: flex;
    align-items: flex-start;
    gap: 7px;
    font-size: 12px;
    color: #5f5e5a;
    margin-bottom: 5px;
  }
  .cp-icon { width: 14px; height: 14px; flex-shrink: 0; margin-top: 1px; }
  .cp-sec {
    margin-top: 12px;
    border-top: 1px solid #e8e5dc;
    padding-top: 10px;
  }
  .cp-sec-title {
    font-size: 10px;
    font-weight: 600;
    color: #a0a098;
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-bottom: 7px;
  }
  .cp-chip {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 8px;
    border-radius: 6px;
    background: #f4f4f0;
    margin-bottom: 3px;
    font-size: 12px;
    color: #2c2c2a;
    cursor: pointer;
    border: none;
    width: 100%;
    text-align: left;
  }
  .cp-chip:hover { background: #e8e5dc; }
  .cp-chip-type { font-size: 10px; color: #a0a098; margin-left: auto; }
  .cp-close {
    float: right;
    background: none;
    border: none;
    cursor: pointer;
    color: #888;
    font-size: 16px;
    line-height: 1;
    padding: 0;
  }

  /* États SVG */
  .carte-bldg-grp { cursor: pointer; }
  .carte-bldg-grp.is-dimmed { opacity: .18; transition: opacity .15s; }
  .carte-bldg-grp.is-lit .carte-bldg-rect { stroke-width: 2.5 !important; }
  .carte-bldg-grp:hover:not(.is-dimmed) { filter: brightness(1.06); }
</style>

<%# ═══════════ JS ═══════════ %>
<script>
(function() {
  const TYPE_FR = {
    ward_open: "Unité ouverte", ward_closed: "Unité fermée", cmp: "CMP",
    hdj: "Hôpital de jour", cattp: "CATTP", csapa: "CSAPA", utep: "UTEP",
    empp: "EMPP", expert_center: "Centre expert", users_house: "Maison des usagers",
    cump: "CUMP", ulpsy: "ULPSY", long_stay: "Longue durée",
    crisis_unit: "Unité de crise", perinatal: "Psychiatrie périnatale",
    sessad: "SESSAD", camsp: "CAMSP", mas: "MAS", other: "Service"
  };

  const wrapper  = document.querySelector('.carte-main-wrap');
  const unitsData = JSON.parse(wrapper.dataset.units || '{}');

  // Construit un index pole_slug -> { name, color } depuis les données
  const polesIndex = {};
  Object.values(unitsData).forEach(u => {
    if (!polesIndex[u.pole]) {
      polesIndex[u.pole] = { name: u.pole_name, color: u.pole_color };
    }
  });
  // Services généraux (pas de pôle dans la seed)
  polesIndex['services'] = { name: 'Services généraux', color: '#c8c3b8' };

  // Couleur de texte contrastée (très simple : fond clair = texte foncé)
  function darkened(hex) {
    const r = parseInt(hex.slice(1,3),16),
          g = parseInt(hex.slice(3,5),16),
          b = parseInt(hex.slice(5,7),16);
    const lum = (0.299*r + 0.587*g + 0.114*b) / 255;
    return lum > 0.5 ? '#1a1a18' : '#ffffff';
  }
  function lightened(hex) {
    // Version très claire du fond pour badge
    return hex + '33'; // ~20% opacity — on utilisera inline rgba
  }

  let activeSvgId = null;
  let activePole  = null;

  function allBldgs() {
    return document.querySelectorAll('#carte-plansvg .carte-bldg-grp[data-svg-id]');
  }

  function resetAll() {
    allBldgs().forEach(el => {
      el.classList.remove('is-dimmed', 'is-lit');
    });
    activeSvgId = null;
    activePole  = null;
    document.getElementById('carte-panel-empty').style.display   = 'block';
    document.getElementById('carte-panel-content').style.display = 'none';
    document.getElementById('carte-panel-content').innerHTML     = '';
    document.querySelectorAll('.carte-leg').forEach(l => l.classList.remove('is-on'));
    document.getElementById('carte-search').value = '';
    document.getElementById('carte-clear').style.display = 'none';
  }

  function highlightBldg(svgId) {
    activeSvgId = svgId;
    activePole  = null;
    allBldgs().forEach(el => {
      if (el.dataset.svgId === svgId) {
        el.classList.remove('is-dimmed');
        el.classList.add('is-lit');
      } else {
        el.classList.add('is-dimmed');
        el.classList.remove('is-lit');
      }
    });
    showPanel(svgId);
  }

  function filterPole(poleSlug, legEl) {
    if (activePole === poleSlug) { resetAll(); return; }
    activePole  = poleSlug;
    activeSvgId = null;
    document.querySelectorAll('.carte-leg').forEach(l => l.classList.remove('is-on'));
    legEl.classList.add('is-on');
    allBldgs().forEach(el => {
      const unitInfo = unitsData[el.dataset.svgId];
      const elPole = unitInfo ? unitInfo.pole : 'services';
      el.classList.toggle('is-dimmed', elPole !== poleSlug);
      el.classList.remove('is-lit');
    });
    document.getElementById('carte-panel-empty').style.display   = 'block';
    document.getElementById('carte-panel-content').style.display = 'none';
  }

  function showPanel(svgId) {
    const u = unitsData[svgId];
    if (!u) return;

    const poleInfo = polesIndex[u.pole] || polesIndex['services'];
    const badgeBg  = poleInfo.color + '33';
    const badgeTxt = darkened(poleInfo.color);

    // Autres bâtiments du même pôle
    const siblings = Array.from(allBldgs()).filter(el => {
      if (el.dataset.svgId === svgId) return false;
      const su = unitsData[el.dataset.svgId];
      return su && su.pole === u.pole;
    });

    const siblingsHtml = siblings.length ? `
      <div class="cp-sec">
        <div class="cp-sec-title">Autres bâtiments — ${poleInfo.name}</div>
        ${siblings.map(el => {
          const su = unitsData[el.dataset.svgId];
          return su ? `
            <button class="cp-chip" data-goto="${el.dataset.svgId}">
              <span>${su.name}</span>
              <span class="cp-chip-type">${TYPE_FR[su.type] || ''}</span>
            </button>` : '';
        }).join('')}
      </div>` : '';

    const pc = document.getElementById('carte-panel-content');
    const pe = document.getElementById('carte-panel-empty');
    pe.style.display = 'none';
    pc.style.display = 'block';
    pc.innerHTML = `
      <button class="cp-close" id="carte-panel-close" aria-label="Fermer">✕</button>
      <div class="cp-badge" style="background:${badgeBg};color:${badgeTxt}">${poleInfo.name}</div>
      <div class="cp-name">${u.name}</div>
      <div class="cp-type">${TYPE_FR[u.type] || u.type}${u.cap ? ' · ' + u.cap + ' lits/places' : ''}</div>
      <div class="cp-desc">${u.desc}</div>
      ${u.phone ? `
        <div class="cp-row">
          <svg class="cp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.1 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
          <span>${u.phone}</span>
        </div>` : ''}
      ${u.email ? `
        <div class="cp-row">
          <svg class="cp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span style="word-break:break-all;font-size:11px">${u.email}</span>
        </div>` : ''}
      <div class="cp-row">
        <svg class="cp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        <span>${u.pmr ? 'Accès PMR disponible' : 'Non accessible PMR'}</span>
      </div>
      ${siblingsHtml}
    `;

    document.getElementById('carte-panel-close').addEventListener('click', resetAll);
    pc.querySelectorAll('[data-goto]').forEach(btn => {
      btn.addEventListener('click', () => highlightBldg(btn.dataset.goto));
    });
  }

  // Attache les events sur les groupes SVG
  allBldgs().forEach(el => {
    el.setAttribute('tabindex', '0');
    el.setAttribute('role', 'button');
    const u = unitsData[el.dataset.svgId];
    if (u) el.setAttribute('aria-label', u.name);
    el.addEventListener('click', () => highlightBldg(el.dataset.svgId));
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') highlightBldg(el.dataset.svgId);
    });
  });

  // Légende filtre pôle
  const legbar = document.getElementById('carte-legbar');
  Object.entries(polesIndex).forEach(([slug, p]) => {
    const d = document.createElement('div');
    d.className = 'carte-leg';
    d.dataset.pole = slug;
    d.innerHTML = `<span class="carte-leg-sq" style="background:${p.color}"></span>${p.name}`;
    d.addEventListener('click', () => filterPole(slug, d));
    legbar.appendChild(d);
  });

  // Recherche
  const searchEl = document.getElementById('carte-search');
  const clearBtn = document.getElementById('carte-clear');
  searchEl.addEventListener('input', function() {
    const q = this.value.trim().toLowerCase();
    clearBtn.style.display = q ? 'inline' : 'none';
    if (!q) {
      allBldgs().forEach(el => el.classList.remove('is-dimmed', 'is-lit'));
      document.getElementById('carte-panel-empty').style.display   = 'block';
      document.getElementById('carte-panel-content').style.display = 'none';
      return;
    }
    const matches = [];
    allBldgs().forEach(el => {
      const u = unitsData[el.dataset.svgId];
      const p = u ? (polesIndex[u.pole] || {}) : {};
      const hit = u && (
        u.name.toLowerCase().includes(q) ||
        (TYPE_FR[u.type] || '').toLowerCase().includes(q) ||
        (p.name || '').toLowerCase().includes(q)
      );
      el.classList.toggle('is-dimmed', !hit);
      el.classList.remove('is-lit');
      if (hit) matches.push(el.dataset.svgId);
    });
    if (matches.length === 1) highlightBldg(matches[0]);
  });
  clearBtn.addEventListener('click', resetAll);

})();
</script>
