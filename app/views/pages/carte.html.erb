<%# ═══════════ HUB HERO ═══════════ %>
<section class="hub-hero" style="--accent: #1f5e5c;" aria-labelledby="carte-title">
  <div class="container">
    <span class="label">Navigation</span>
    <h1 id="carte-title">Plan <span class="hub-hero-accent">de l'établissement</span></h1>
    <p>
      Retrouvez chaque unité sur le plan schématique du CH Polaris.
      Cliquez sur un bâtiment pour afficher ses informations.
    </p>
  </div>
</section>

<%# ═══════════ PLAN SVG INTERACTIF ═══════════ %>
<div class="container">
  <section class="section section--no-border">

    <%# Barre de recherche + légende %>
    <div class="carte-toolbar">
      <div class="carte-search-wrap">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="carte-search" placeholder="Rechercher une unité, un pôle…" autocomplete="off">
        <button id="carte-clear" class="carte-clear-btn" aria-label="Effacer la recherche" style="display:none">✕</button>
      </div>
    </div>

    <div class="carte-legend-bar" id="carte-legbar"></div>

    <%# Wrapper plan + panneau côte à côte %>
<div class="carte-main-wrap"
     data-units="<%= json_escape(@poles.flat_map { |pole|
       pole.units.map { |u|
         [u.svg_zone_id, {
           name:       u.name,
           type:       u.unit_type,
           cap:        u.capacity,
           phone:      u.phone,
           email:      u.email,
           pmr:        u.pmr_accessible,
           desc:       u.description,
           pole:       pole.slug,
           pole_name:  pole.name,
           pole_color: pole.color
         }]
       }
     }.to_h.to_json) %>">

      <%# ── Plan SVG ── %>
      <div class="carte-svg-col">
        <svg width="100%" viewBox="0 0 1000 1000" role="img" xmlns="http://www.w3.org/2000/svg" id="carte-plansvg">
          <title>Plan pavillonnaire du Centre Hospitalier Polaris</title>
          <desc>Plan schématique du CH Polaris avec 5 pôles et 32 bâtiments.</desc>

          <defs>
            <pattern id="carte-grass" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
              <rect width="14" height="14" fill="#d8e2c0"/>
              <circle cx="3" cy="4" r="0.7" fill="#bccea0"/>
              <circle cx="10" cy="9" r="0.6" fill="#bccea0"/>
              <circle cx="6" cy="11" r="0.5" fill="#c4d3a9"/>
            </pattern>
            <pattern id="carte-park" x="0" y="0" width="14" height="22" patternUnits="userSpaceOnUse">
              <rect width="14" height="22" fill="#bdb8a8"/>
              <line x1="14" y1="2" x2="14" y2="20" stroke="#ffffff" stroke-width="0.8"/>
            </pattern>
            <filter id="carte-shadow" x="-10%" y="-10%" width="130%" height="130%">
              <feOffset in="SourceGraphic" dx="3" dy="3" result="off"/>
              <feColorMatrix in="off" type="matrix" values="0 0 0 0 0.2  0 0 0 0 0.2  0 0 0 0 0.18  0 0 0 0.28 0" result="sh"/>
              <feGaussianBlur in="sh" stdDeviation="0.7" result="shb"/>
              <feMerge><feMergeNode in="shb"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <style>
            .carte-ts { font-family: sans-serif; font-size: 11px; font-weight: 400; }
            .carte-rue { font-family: sans-serif; font-size: 11px; font-weight: 500; fill: #6b6b5f; letter-spacing: 1.5px; }
            .carte-legend { font-family: sans-serif; font-size: 11px; fill: #2c2c2a; }
            .carte-num { font-family: sans-serif; font-size: 9px; font-weight: 700; fill: #ffffff; }
            .carte-bldg { font-family: sans-serif; font-size: 11px; font-weight: 500; }
            .carte-bldg-lg { font-family: sans-serif; font-size: 13px; font-weight: 600; }
            .carte-bldg-grp { cursor: pointer; transition: opacity .15s; }
            .carte-bldg-grp:hover .carte-bldg-rect { opacity: .75; }
            .carte-bldg-grp.is-dimmed { opacity: .2; }
            .carte-bldg-grp.is-lit .carte-bldg-rect { stroke-width: 2.5 !important; }
          </style>

          <rect x="0" y="0" width="1000" height="1000" fill="#eef0ea"/>
          <path d="M 60 40 L 900 35 L 960 100 L 970 380 L 965 660 L 920 800 L 880 900 L 600 920 L 400 915 L 140 895 L 55 760 L 35 380 L 45 130 Z" fill="url(#carte-grass)" stroke="#7a7867" stroke-width="1.6"/>

          <text x="480" y="22" text-anchor="middle" class="carte-rue">RUE DES CONSTELLATIONS</text>
          <text x="18" y="480" text-anchor="middle" class="carte-rue" transform="rotate(-90 18 480)">ALLÉE GALILÉE</text>
          <text x="985" y="500" text-anchor="middle" class="carte-rue" transform="rotate(90 985 500)">ALLÉE COPERNIC</text>
          <text x="480" y="945" text-anchor="middle" class="carte-rue">RUE KEPLER</text>

