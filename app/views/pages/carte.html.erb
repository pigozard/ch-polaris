    <!-- Annuaire des unités par pôle en attendant -->
    <div style="margin-top: 56px;">
      <span class="label">En attendant le plan</span>
      <h2 class="section-title" style="margin-bottom: 32px;">Unités par pôle</h2>

      <% @poles.each do |pole| %>
        <div class="carte-pole-block">
          <div class="carte-pole-header">
            <span class="carte-pole-dot" style="background-color: <%= pole.color %>;" aria-hidden="true"></span>
            <h3 class="carte-pole-name"><%= pole.name %></h3>
            <span class="carte-pole-count"><%= pole.units.count %> unités</span>
          </div>
          <div class="carte-units-list">
            <% pole.units.ordered.each do |unit| %>
              <div class="carte-unit-item">
                <span class="carte-unit-name"><%= unit.name %></span>
                <span class="carte-unit-type"><%= unit_type_fr(unit.unit_type) %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  </section>
</div>
