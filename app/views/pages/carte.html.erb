<!-- ═══════════ HUB HERO ═══════════ -->
<section class="hub-hero" style="--accent: #1f5e5c;" aria-labelledby="carte-title">
  <div class="container">
    <span class="label">Navigation</span>
    <h1 id="carte-title">Plan <span class="hub-hero-accent">de l'établissement</span></h1>
    <p>
      Retrouvez chaque unité sur le plan schématique du CH Polaris.
      Recherchez une unité — sa zone s'illumine sur le plan.
    </p>
  </div>
</section>

<!-- ═══════════ PLAN SVG ═══════════ -->
<div class="container">
  <section class="section section--no-border">

    <div class="carte-svg-wrapper" aria-label="Plan schématique du Centre Hospitalier Polaris — interactivité à venir">
      <div class="carte-svg-legend-bar">
        <span class="carte-coming-badge">Interactivité — semaine 8</span>
        <span class="carte-svg-hint">Recherche et illumination des zones à venir</span>
      </div>

      <svg width="100%" viewBox="0 0 680 580" role="img" xmlns="http://www.w3.org/2000/svg">
        <title>Plan pavillonnaire du Centre Hospitalier Polaris</title>
        <desc>Plan schématique du CH Polaris avec 5 pôles : Cassiopée (adulte nord), Orion (adulte sud), Lyra (addictologie), Pléiades (enfant et ado), Polaris (transversal).</desc>

        <style>
          .ground { fill: #e8ede8; }
          .green  { fill: #c8ddb0; }
          .allee  { fill: #d4cfc4; stroke: #bbb8b0; stroke-width: 0.5; }
          .water  { fill: #b8d4e8; }
          .pavillon { stroke-width: 1; }
          .pav-label { font-family: sans-serif; font-size: 11px; font-weight: 600; }
          .pav-sub   { font-family: sans-serif; font-size: 9px;  font-weight: 400; }
          .entree-label { font-family: sans-serif; font-size: 10px; fill: #555; }
          .legend-label { font-family: sans-serif; font-size: 10px; fill: #333; }
          .border { fill: none; stroke: #a0a090; stroke-width: 1.5; stroke-dasharray: 5 3; }
        </style>

        <rect width="680" height="580" fill="#eef0ea"/>
        <rect class="border" x="20" y="20" width="640" height="540" rx="8"/>
        <rect class="green" x="30" y="30" width="620" height="520" rx="6"/>

        <rect class="allee" x="310" y="30"  width="24"  height="520"/>
        <rect class="allee" x="30"  y="280" width="620" height="22"/>
        <rect class="allee" x="30"  y="180" width="295" height="16"/>
        <rect class="allee" x="356" y="180" width="294" height="16"/>
        <rect class="allee" x="30"  y="390" width="295" height="16"/>
        <rect class="allee" x="356" y="390" width="294" height="16"/>

        <ellipse class="water" cx="322" cy="301" rx="22" ry="16"/>

        <rect class="green" x="55"  y="55"  width="30" height="20" rx="10"/>
        <rect class="green" x="100" y="48"  width="20" height="28" rx="10"/>
        <rect class="green" x="200" y="52"  width="28" height="18" rx="9"/>
        <rect class="green" x="400" y="50"  width="22" height="30" rx="11"/>
        <rect class="green" x="500" y="55"  width="35" height="18" rx="9"/>
        <rect class="green" x="580" y="48"  width="24" height="26" rx="12"/>
        <rect class="green" x="55"  y="470" width="28" height="22" rx="11"/>
        <rect class="green" x="120" y="475" width="20" height="28" rx="10"/>
        <rect class="green" x="420" y="468" width="32" height="24" rx="12"/>
        <rect class="green" x="560" y="472" width="26" height="20" rx="10"/>
        <rect class="green" x="370" y="340" width="18" height="24" rx="9"/>
        <rect class="green" x="490" y="335" width="22" height="18" rx="9"/>
        <rect class="green" x="80"  y="340" width="20" height="20" rx="10"/>
        <rect class="green" x="180" y="335" width="26" height="18" rx="9"/>

        <g id="zone-cassiopee">
          <rect class="pavillon" x="45"  y="70" width="130" height="90" rx="5" fill="#dbeafe" stroke="#3b82f6"/>
          <rect class="pavillon" x="185" y="75" width="95"  height="40" rx="4" fill="#bfdbfe" stroke="#3b82f6"/>
          <rect class="pavillon" x="185" y="123" width="95" height="37" rx="4" fill="#bfdbfe" stroke="#3b82f6"/>
          <text x="110" y="108" text-anchor="middle" class="pav-label" fill="#1e40af">Cassiopée</text>
          <text x="110" y="121" text-anchor="middle" class="pav-sub"   fill="#1e40af">Adulte Nord</text>
          <text x="233" y="100" text-anchor="middle" class="pav-sub"   fill="#1e40af">Andromède</text>
          <text x="233" y="147" text-anchor="middle" class="pav-sub"   fill="#1e40af">Persée</text>
        </g>

        <g id="zone-orion">
          <rect class="pavillon" x="356" y="70"  width="130" height="90" rx="5" fill="#fef3c7" stroke="#f59e0b"/>
          <rect class="pavillon" x="496" y="75"  width="100" height="40" rx="4" fill="#fde68a" stroke="#f59e0b"/>
          <rect class="pavillon" x="496" y="123" width="100" height="37" rx="4" fill="#fde68a" stroke="#f59e0b"/>
          <text x="421" y="108" text-anchor="middle" class="pav-label" fill="#92400e">Orion</text>
          <text x="421" y="121" text-anchor="middle" class="pav-sub"   fill="#92400e">Adulte Sud</text>
          <text x="546" y="100" text-anchor="middle" class="pav-sub"   fill="#92400e">Bételgeuse</text>
          <text x="546" y="147" text-anchor="middle" class="pav-sub"   fill="#92400e">Rigel</text>
        </g>

        <g id="zone-lyra">
          <rect class="pavillon" x="45"  y="205" width="115" height="60" rx="5" fill="#ede9fe" stroke="#8b5cf6"/>
          <rect class="pavillon" x="168" y="205" width="112" height="60" rx="5" fill="#ddd6fe" stroke="#8b5cf6"/>
          <text x="103" y="231" text-anchor="middle" class="pav-label" fill="#4c1d95">Lyra</text>
          <text x="103" y="244" text-anchor="middle" class="pav-sub"   fill="#4c1d95">Addictologie</text>
          <text x="224" y="228" text-anchor="middle" class="pav-sub"   fill="#4c1d95">Véga / Altaïr</text>
          <text x="224" y="241" text-anchor="middle" class="pav-sub"   fill="#4c1d95">CMP · HDJ</text>
        </g>

        <g id="zone-pleiades">
          <rect class="pavillon" x="356" y="205" width="145" height="65" rx="5" fill="#d1fae5" stroke="#10b981"/>
          <rect class="pavillon" x="509" y="205" width="87"  height="65" rx="4" fill="#a7f3d0" stroke="#10b981"/>
          <text x="429" y="233" text-anchor="middle" class="pav-label" fill="#065f46">Pléiades</text>
          <text x="429" y="246" text-anchor="middle" class="pav-sub"   fill="#065f46">Enfant &amp; Ado</text>
          <text x="553" y="230" text-anchor="middle" class="pav-sub"   fill="#065f46">Maia</text>
          <text x="553" y="243" text-anchor="middle" class="pav-sub"   fill="#065f46">Alcyone</text>
          <text x="553" y="256" text-anchor="middle" class="pav-sub"   fill="#065f46">HDJ · SESSAD</text>
        </g>

        <g id="zone-polaris">
          <rect class="pavillon" x="45"  y="310" width="590" height="195" rx="6" fill="#f0fdf4" stroke="#1f5e5c" stroke-width="1.5"/>
          <rect class="pavillon" x="58"  y="325" width="100" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="168" y="325" width="100" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="278" y="325" width="100" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="388" y="325" width="100" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="498" y="325" width="120" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="58"  y="385" width="225" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="293" y="385" width="225" height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="528" y="385" width="90"  height="50"  rx="4" fill="#ccfbf1" stroke="#1f5e5c"/>
          <rect class="pavillon" x="58"  y="445" width="560" height="45"  rx="4" fill="#99f6e4" stroke="#1f5e5c"/>
          <text x="108" y="347" text-anchor="middle" class="pav-sub"   fill="#134e4a">CUMP</text>
          <text x="108" y="358" text-anchor="middle" class="pav-sub"   fill="#134e4a">Polaris</text>
          <text x="218" y="347" text-anchor="middle" class="pav-sub"   fill="#134e4a">UTEP</text>
          <text x="218" y="358" text-anchor="middle" class="pav-sub"   fill="#134e4a">Étoile Polaire</text>
          <text x="328" y="347" text-anchor="middle" class="pav-sub"   fill="#134e4a">Centre Expert</text>
          <text x="328" y="358" text-anchor="middle" class="pav-sub"   fill="#134e4a">Sirius</text>
          <text x="438" y="347" text-anchor="middle" class="pav-sub"   fill="#134e4a">Centre Expert</text>
          <text x="438" y="358" text-anchor="middle" class="pav-sub"   fill="#134e4a">Capella</text>
          <text x="558" y="347" text-anchor="middle" class="pav-sub"   fill="#134e4a">Centre Expert</text>
          <text x="558" y="358" text-anchor="middle" class="pav-sub"   fill="#134e4a">Arcturus</text>
          <text x="171" y="407" text-anchor="middle" class="pav-sub"   fill="#134e4a">Maison Boussole · EMPP Lumière</text>
          <text x="406" y="407" text-anchor="middle" class="pav-sub"   fill="#134e4a">EMPP Aurore · ULPSY · ULD</text>
          <text x="573" y="407" text-anchor="middle" class="pav-sub"   fill="#134e4a">Liaison</text>
          <text x="338" y="469" text-anchor="middle" class="pav-label" fill="#134e4a">Pôle Polaris — Structures transversales</text>
        </g>

        <rect class="allee" x="296" y="540" width="88" height="18" rx="3"/>
        <text x="340" y="553" text-anchor="middle" class="entree-label">Entrée principale</text>

        <rect x="30"  y="510" width="8" height="8" fill="#dbeafe" stroke="#3b82f6" stroke-width="0.8" rx="1"/>
        <text x="42"  y="519" class="legend-label">Cassiopée</text>
        <rect x="110" y="510" width="8" height="8" fill="#fef3c7" stroke="#f59e0b" stroke-width="0.8" rx="1"/>
        <text x="122" y="519" class="legend-label">Orion</text>
        <rect x="170" y="510" width="8" height="8" fill="#ede9fe" stroke="#8b5cf6" stroke-width="0.8" rx="1"/>
        <text x="182" y="519" class="legend-label">Lyra</text>
        <rect x="224" y="510" width="8" height="8" fill="#d1fae5" stroke="#10b981" stroke-width="0.8" rx="1"/>
        <text x="236" y="519" class="legend-label">Pléiades</text>
        <rect x="296" y="510" width="8" height="8" fill="#ccfbf1" stroke="#1f5e5c" stroke-width="0.8" rx="1"/>
        <text x="308" y="519" class="legend-label">Polaris</text>
        <rect x="27"  y="506" width="640" height="18" fill="none" stroke="#ccc" stroke-width="0.5" rx="2"/>
      </svg>
    </div>

    <!-- Annuaire des unités par pôle en attendant -->
    <div style="margin-top: 56px;">
      <span class="label">En attendant le plan</span>
      <h2 class="section-title" style="margin-bottom: 32px;">Unités par pôle</h2>

      <% @poles.each do |pole| %>
        <div class="carte-pole-block">
          <div class="carte-pole-header">
            <span class="carte-pole-dot" style="background-color: <%= pole.color %>;" aria-hidden="true"></span>
            <h3 class="carte-pole-name"><%= pole.name %></h3>
            <span class="carte-pole-count"><%= pole.units.count %> unités</span>
          </div>
          <div class="carte-units-list">
            <% pole.units.ordered.each do |unit| %>
              <div class="carte-unit-item">
                <span class="carte-unit-name"><%= unit.name %></span>
                <span class="carte-unit-type"><%= unit_type_fr(unit.unit_type) %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  </section>
</div>
