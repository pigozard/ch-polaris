<!-- ═══════════ HERO ÉTABLISSEMENT ═══════════ -->
<section class="hopital-hero" aria-labelledby="hopital-title">
  <div class="container">
    <span class="label">Notre établissement</span>
    <h1 class="hopital-hero-title" id="hopital-title">
      Centre Hospitalier Polaris<br>
      <span class="hopital-hero-accent">psychiatrie de territoire depuis 1968</span>
    </h1>
    <p class="hopital-hero-lead">
      Établissement public de santé dédié à la psychiatrie adulte, pédopsychiatrique
      et à l'addictologie. <%= @poles.count %> pôles, <%= Unit.count %> unités,
      un continuum de soins du CMP à l'hospitalisation complète.
    </p>
    <nav class="hopital-anchors" aria-label="Sections de la page">
      <a href="#offre" class="hopital-anchor">Offre de soins</a>
      <a href="#poles" class="hopital-anchor">Nos pôles</a>
      <a href="#actualites" class="hopital-anchor">Actualités</a>
      <a href="#contact" class="hopital-anchor">Contact</a>
    </nav>
  </div>
</section>

<!-- ═══════════ OFFRE DE SOINS ═══════════ -->
<div class="section--alt" id="offre">
  <div class="container">
    <section class="section section--no-border" aria-labelledby="offre-title"
             data-controller="tabs">

      <div class="section-header">
        <div>
          <span class="label">Nos services</span>
          <h2 class="section-title" id="offre-title">Une prise en charge complète et coordonnée</h2>
        </div>
      </div>

      <div class="tabs-nav" role="tablist" aria-label="Offre de soins">
        <button class="tab-btn active"
                data-tab="soins" data-tabs-target="btn"
                data-action="click->tabs#select keydown->tabs#navigate"
                role="tab" aria-selected="true"
                aria-controls="h-tab-soins" id="h-btn-soins">
          Soins & Hospitalisation
        </button>
        <button class="tab-btn"
                data-tab="etp" data-tabs-target="btn"
                data-action="click->tabs#select keydown->tabs#navigate"
                role="tab" aria-selected="false"
                aria-controls="h-tab-etp" id="h-btn-etp">
          Éducation Thérapeutique
        </button>
        <button class="tab-btn"
                data-tab="numerique" data-tabs-target="btn"
                data-action="click->tabs#select keydown->tabs#navigate"
                role="tab" aria-selected="false"
                aria-controls="h-tab-numerique" id="h-btn-numerique">
          Numérique & Innovation
        </button>
        <button class="tab-btn"
                data-tab="urgences" data-tabs-target="btn"
                data-action="click->tabs#select keydown->tabs#navigate"
                role="tab" aria-selected="false"
                aria-controls="h-tab-urgences" id="h-btn-urgences">
          Urgences Psychiatriques
        </button>
        <button class="tab-btn"
                data-tab="patients" data-tabs-target="btn"
                data-action="click->tabs#select keydown->tabs#navigate"
                role="tab" aria-selected="false"
                aria-controls="h-tab-patients" id="h-btn-patients">
          Espace Patients
        </button>
      </div>

      <div class="tab-panel active" id="h-tab-soins" data-tab="soins"
           data-tabs-target="panel" role="tabpanel"
           aria-labelledby="h-btn-soins" aria-hidden="false" tabindex="-1">
        <div class="tab-content">
          <h3>Hospitalisations et soins ambulatoires</h3>
          <p>Du suivi ambulatoire à l'hospitalisation complète, un continuum de soins adapté à chaque situation clinique et à chaque parcours de vie.</p>
          <ul class="tab-list">
            <li>Hospitalisation complète ouverte et fermée</li>
            <li>Centres médico-psychologiques (CMP) de secteur</li>
            <li>Hôpital de jour adulte et pédopsychiatrique</li>
            <li>Centres d'Accueil Thérapeutique à Temps Partiel</li>
            <li>Consultations spécialisées et centres experts</li>
          </ul>
        </div>
        <div class="tab-visual" aria-hidden="true">
          <div class="tab-visual-icon">🏥</div>
          <div class="tab-visual-label">Soins & Parcours</div>
        </div>
      </div>

      <div class="tab-panel" id="h-tab-etp" data-tab="etp"
           data-tabs-target="panel" role="tabpanel"
           aria-labelledby="h-btn-etp" aria-hidden="true" tabindex="-1">
        <div class="tab-content">
          <h3>Unité Transversale d'Éducation du Patient</h3>
          <p>L'UTEP Étoile Polaire coordonne les programmes d'éducation thérapeutique pour l'ensemble de l'établissement, en lien avec les cinq pôles.</p>
          <ul class="tab-list">
            <li>5 programmes ETP validés ARS</li>
            <li>Groupes thérapeutiques et séances individuelles</li>
            <li>Coordination interprofessionnelle</li>
            <li>Intégration des proches aidants</li>
            <li>Évaluation continue des programmes</li>
          </ul>
        </div>
        <div class="tab-visual" aria-hidden="true">
          <div class="tab-visual-icon">📚</div>
          <div class="tab-visual-label">Éducation Thérapeutique</div>
        </div>
      </div>

      <div class="tab-panel" id="h-tab-numerique" data-tab="numerique"
           data-tabs-target="panel" role="tabpanel"
           aria-labelledby="h-btn-numerique" aria-hidden="true" tabindex="-1">
        <div class="tab-content">
          <h3>Innovation numérique en santé mentale</h3>
          <p>Le CH Polaris intègre les outils numériques pour améliorer la coordination des soins, l'expérience patient et la continuité ville-hôpital.</p>
          <ul class="tab-list">
            <li>Dossier Patient Informatisé (DPI) unifié</li>
            <li>Téléconsultation psychiatrique</li>
            <li>Outils d'évaluation et de suivi numériques</li>
            <li>Coordination ville-hôpital digitalisée</li>
            <li>Plateforme e-santé pour les professionnels</li>
          </ul>
        </div>
        <div class="tab-visual" aria-hidden="true">
          <div class="tab-visual-icon">💻</div>
          <div class="tab-visual-label">e-Santé & Digital</div>
        </div>
      </div>

      <div class="tab-panel" id="h-tab-urgences" data-tab="urgences"
           data-tabs-target="panel" role="tabpanel"
           aria-labelledby="h-btn-urgences" aria-hidden="true" tabindex="-1">
        <div class="tab-content">
          <h3>Urgences et interventions de crise</h3>
          <p>Une organisation dédiée aux situations de crise psychiatrique, 24h/24, en lien avec le SAMU et les partenaires du territoire.</p>
          <ul class="tab-list">
            <li>Équipe Psychiatrique d'Intervention et de Crise (EPIC)</li>
            <li>Cellule d'urgence médico-psychologique (CUMP)</li>
            <li>Unité de liaison psychiatrique (ULPSY)</li>
            <li>Dispositif de postvention et suivi de crise</li>
            <li>Coordination SAMU — 15 et 3114</li>
          </ul>
        </div>
        <div class="tab-visual" aria-hidden="true">
          <div class="tab-visual-icon">🚨</div>
          <div class="tab-visual-label">Crise & Urgences</div>
        </div>
      </div>

      <div class="tab-panel" id="h-tab-patients" data-tab="patients"
           data-tabs-target="panel" role="tabpanel"
           aria-labelledby="h-btn-patients" aria-hidden="true" tabindex="-1">
        <div class="tab-content">
          <h3>Espace patients & familles</h3>
          <p>Des ressources et des services pour accompagner patients et proches à chaque étape du parcours de soins.</p>
          <ul class="tab-list">
            <li>Sectorisation et orientation vers le bon CMP</li>
            <li>Droits des patients en psychiatrie</li>
            <li>Préparer son séjour — règlements par unité</li>
            <li>FAQ et guides pratiques</li>
            <li>Maison des Usagers — La Maison Boussole</li>
          </ul>
        </div>
        <div class="tab-visual" aria-hidden="true">
          <div class="tab-visual-icon">👥</div>
          <div class="tab-visual-label">Patients & Familles</div>
        </div>
      </div>

    </section>
  </div>
</div>

<!-- ═══════════ PÔLES ═══════════ -->
<div class="container" id="poles">
  <section class="section" aria-labelledby="poles-title">
    <div class="section-header">
      <div>
        <span class="label">Organisation clinique</span>
        <h2 class="section-title" id="poles-title">Cinq pôles d'expertise</h2>
      </div>
      <span class="section-meta"><%= Unit.count %> unités au total</span>
    </div>
    <div class="poles-grid">
      <% @poles.each_with_index do |pole, index| %>
        <article class="pole-card">
          <div class="pole-accent" style="background-color: <%= pole.color %>;" aria-hidden="true"></div>
          <div class="pole-num" aria-hidden="true">0<%= index + 1 %></div>
          <h3 class="pole-name"><%= pole.name %></h3>
          <p class="pole-desc"><%= truncate(pole.description, length: 120) %></p>
          <p class="pole-count"><%= pole.units.count %> unités</p>
        </article>
      <% end %>
    </div>
  </section>
</div>

<!-- ═══════════ ACTUALITÉS ═══════════ -->
<% if @news.any? %>
<div class="section--alt" id="actualites">
  <div class="container">
    <section class="section section--no-border" aria-labelledby="news-title">
      <div class="section-header">
        <div>
          <span class="label">Vie de l'établissement</span>
          <h2 class="section-title" id="news-title">Actualités</h2>
        </div>
      </div>
      <div class="news-grid">
        <% @news.each do |article| %>
          <article class="news-card">
            <p class="news-cat"><%= category_fr(article.category) %></p>
            <h3 class="news-title"><%= article.title %></h3>
            <p class="news-summary"><%= article.summary %></p>
            <div class="news-meta">
              <time datetime="<%= article.published_at&.iso8601 %>">
                <%= article.published_at&.strftime("%d %B %Y") %>
              </time>
              <% if article.pole %>
                <span class="news-dot" style="background-color: <%= article.pole.color %>;" aria-hidden="true"></span>
                <span><%= article.pole.name %></span>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</div>
<% end %>

<!-- ═══════════ CONTACT ═══════════ -->
<div class="container" id="contact">
  <section class="section" aria-labelledby="contact-title">
    <div class="section-header">
      <div>
        <span class="label">Nous joindre</span>
        <h2 class="section-title" id="contact-title">Contact & accès</h2>
      </div>
    </div>
    <div class="hopital-contact-grid">
      <div class="hopital-contact-card">
        <h3 class="hopital-contact-label">Standard général</h3>
        <a href="tel:0599000000" class="hopital-contact-value">05 99 00 00 00</a>
        <p class="hopital-contact-note">Du lundi au vendredi, 8h – 18h</p>
      </div>
      <div class="hopital-contact-card">
        <h3 class="hopital-contact-label">Adresse</h3>
        <address class="hopital-contact-value" style="font-style:normal;">
          12 rue des Astres<br>33999 Novapolis
        </address>
      </div>
      <div class="hopital-contact-card">
        <h3 class="hopital-contact-label">Contact email</h3>
        <a href="mailto:contact@ch-polaris.fr" class="hopital-contact-value">contact@ch-polaris.fr</a>
        <p class="hopital-contact-note">Réponse sous 48h ouvrées</p>
      </div>
      <div class="hopital-contact-card hopital-contact-card--urgence">
        <h3 class="hopital-contact-label">Urgence psychiatrique</h3>
        <div class="hopital-contact-value">SAMU <strong>15</strong> · Suicide <strong>3114</strong></div>
        <p class="hopital-contact-note">24h/24, 7j/7, gratuit</p>
      </div>
    </div>
    <div style="margin-top: 32px;">
      <%= link_to patients_path, class: "hopital-cta-link" do %>
        Espace patients & proches →
      <% end %>
      <%= link_to professionnels_path, class: "hopital-cta-link" do %>
        Espace professionnels →
      <% end %>
    </div>
  </section>
</div>
